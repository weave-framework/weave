{
  "name": "@weave-framework/i18n",
  "version": "0.2.105",
  "description": "Weave i18n — optional, signal-native translations with ICU plural/select. Zero third-party deps.",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weave-framework/weave.git",
    "directory": "packages/i18n"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "@weave-framework/runtime": "workspace:*"
  },
  "license": "MIT"
}
