{
  "name": "@weave-framework/cli",
  "version": "0.2.85",
  "description": "Weave CLI ‚Äî `weave build`, `weave dev` (watch + live-reload), `weave check`, `weave routes`.",
  "type": "module",
  "bin": {
    "weave": "./bin/weave.mjs"
  },
  "main": "./src/cli.ts",
  "types": "./src/cli.ts",
  "exports": {
    ".": "./src/cli.ts"
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weave-framework/weave.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "weave": "./bin/weave-dist.mjs"
    },
    "main": "./dist/cli.js",
    "module": "./dist/cli.js",
    "types": "./dist/cli.d.ts",
    "exports": {
      ".": {
        "types": "./dist/cli.d.ts",
        "import": "./dist/cli.js"
      }
    }
  },
  "dependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  },
  "optionalDependencies": {
    "sass": "^1.0.0"
  },
  "license": "MIT"
}
