{
  "name": "@weave-framework/nx",
  "version": "1.5.20",
  "description": "Nx plugin for Weave — inferred build/serve/check targets (crystal createNodesV2), executors, and generators, so a Weave app is a first-class project in an Nx monorepo.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./plugin": "./src/plugin.ts",
    "./package.json": "./package.json"
  },
  "executors": "./executors.json",
  "generators": "./generators.json",
  "files": [
    "dist",
    "executors.json",
    "generators.json",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weave-framework/weave.git",
    "directory": "packages/nx"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./plugin": {
        "types": "./dist/plugin.d.ts",
        "import": "./dist/plugin.js"
      },
      "./package.json": "./package.json"
    }
  },
  "dependencies": {
    "@nx/devkit": "^23.0.1"
  },
  "peerDependencies": {
    "nx": ">=21.0.0"
  },
  "license": "MIT"
}
