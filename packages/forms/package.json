{
  "name": "@weave-framework/forms",
  "version": "0.2.157",
  "description": "Weave forms — signal-native field/form state + validation over bind:value. Zero third-party deps.",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./dom": "./src/dom.ts",
    "./schema": "./src/schema.ts"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weave-framework/weave.git",
    "directory": "packages/forms"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./dom": {
        "types": "./dist/dom.d.ts",
        "import": "./dist/dom.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js"
      }
    }
  },
  "dependencies": {
    "@weave-framework/runtime": "workspace:*"
  },
  "license": "MIT"
}
