{
  "name": "@weave-framework/mcp",
  "version": "1.5.2",
  "description": "Weave MCP server — exposes the Weave toolchain (compile/check/routes/scaffold) to AI agents & editors as Model Context Protocol tools. In-house JSON-RPC over stdio, zero third-party deps.",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "weave-mcp": "./bin/weave-mcp.mjs"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weave-framework/weave.git",
    "directory": "packages/mcp"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "weave-mcp": "./bin/weave-mcp-dist.mjs"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "dependencies": {
    "@weave-framework/compiler": "workspace:*",
    "@weave-framework/check": "workspace:*",
    "@weave-framework/router": "workspace:*"
  },
  "license": "MIT"
}
