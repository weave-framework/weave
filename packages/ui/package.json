{
  "name": "@weave-framework/ui",
  "version": "0.2.0",
  "description": "Weave UI — signal-native component library (Material+CDK equivalent) with the Weave design system. Ships SCSS; zero third-party runtime deps.",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "sass": "./src/styles/_index.scss",
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./divider": {
      "sass": "./src/styles/components/_divider.scss"
    },
    "./ripple": {
      "sass": "./src/styles/components/_ripple.scss",
      "types": "./src/ripple/ripple.ts",
      "import": "./src/ripple/ripple.ts"
    },
    "./icon": {
      "sass": "./src/styles/components/_icon.scss",
      "types": "./src/icon/icon.ts",
      "import": "./src/icon/icon.ts"
    },
    "./button": {
      "sass": "./src/styles/components/_button.scss",
      "types": "./src/button/button.ts",
      "import": "./src/button/button.ts"
    },
    "./button-toggle": {
      "sass": "./src/styles/components/_button-toggle.scss",
      "types": "./src/button-toggle/button-toggle.ts",
      "import": "./src/button-toggle/button-toggle.ts"
    },
    "./cdk": {
      "types": "./src/cdk/index.ts",
      "import": "./src/cdk/index.ts"
    }
  },
  "files": [
    "dist",
    "src/**/*.scss"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weave-framework/weave.git",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "sass": "./src/styles/_index.scss",
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./divider": {
        "sass": "./src/styles/components/_divider.scss"
      },
      "./ripple": {
        "sass": "./src/styles/components/_ripple.scss",
        "types": "./dist/ripple/ripple.d.ts",
        "import": "./dist/ripple/ripple.js"
      },
      "./icon": {
        "sass": "./src/styles/components/_icon.scss",
        "types": "./dist/icon/icon.d.ts",
        "import": "./dist/icon/icon.js"
      },
      "./button": {
        "sass": "./src/styles/components/_button.scss",
        "types": "./dist/button/button.d.ts",
        "import": "./dist/button/button.js"
      },
      "./button-toggle": {
        "sass": "./src/styles/components/_button-toggle.scss",
        "types": "./dist/button-toggle/button-toggle.d.ts",
        "import": "./dist/button-toggle/button-toggle.js"
      },
      "./cdk": {
        "types": "./dist/cdk/index.d.ts",
        "import": "./dist/cdk/index.js"
      }
    }
  },
  "dependencies": {
    "@weave-framework/runtime": "workspace:*"
  },
  "license": "MIT"
}
