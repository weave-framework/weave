{
  "name": "@weave-framework/runtime",
  "version": "1.5.28",
  "description": "Weave reactive core + DOM runtime. Zero dependencies.",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./dom": "./src/dom.ts",
    "./serialize": "./src/serialize.ts",
    "./resume": "./src/resume.ts",
    "./adopt": "./src/adopt.ts",
    "./graph": "./src/graph.ts",
    "./server": "./src/server.ts",
    "./document": "./src/document.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weave-framework/weave.git",
    "directory": "packages/runtime"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./dom": {
        "types": "./dist/dom.d.ts",
        "import": "./dist/dom.js"
      },
      "./serialize": {
        "types": "./dist/serialize.d.ts",
        "import": "./dist/serialize.js"
      },
      "./resume": {
        "types": "./dist/resume.d.ts",
        "import": "./dist/resume.js"
      },
      "./adopt": {
        "types": "./dist/adopt.d.ts",
        "import": "./dist/adopt.js"
      },
      "./graph": {
        "types": "./dist/graph.d.ts",
        "import": "./dist/graph.js"
      },
      "./server": {
        "types": "./dist/server.d.ts",
        "import": "./dist/server.js"
      },
      "./document": {
        "types": "./dist/document.d.ts",
        "import": "./dist/document.js"
      },
      "./package.json": "./package.json"
    }
  },
  "license": "MIT"
}
