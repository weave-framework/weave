{
  "name": "@weave-framework/check",
  "version": "0.2.146",
  "description": "Weave template type-checking — virtual .ts generation + tsc, mapped back to source.",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./emit": "./src/emit.ts"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weave-framework/weave.git",
    "directory": "packages/check"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./emit": {
        "types": "./dist/emit.d.ts",
        "import": "./dist/emit.js"
      }
    }
  },
  "dependencies": {
    "@weave-framework/compiler": "workspace:*"
  },
  "peerDependencies": {
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
