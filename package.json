{
  "name": "weave-monorepo",
  "version": "0.2.0",
  "description": "Weave — fine-grained reactive, signal-native UI framework. Compiled, TypeScript-first, no Virtual DOM.",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "node tools/run-browser-tests.mjs",
    "test:v01": "node --test \"test/**/*.test.mjs\"",
    "verify:build": "node tools/verify-build.mjs"
  },
  "keywords": [
    "reactive",
    "signals",
    "ui",
    "framework",
    "frontend",
    "no-vdom",
    "compiler"
  ],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "esbuild": "^0.24.0",
    "playwright": "^1.49.0",
    "typescript": "^5.7.0"
  },
  "allowScripts": {
    "esbuild@0.24.2": true
  }
}
