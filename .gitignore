# Dependencies
node_modules/

# Build output
dist/
build/
# …but NOT the Nx plugin's `build` EXECUTOR source — the unanchored `build/` above would swallow
# `packages/nx/src/executors/build/`, so it was never committed and the published package shipped
# without its `build` executor (`nx build` → "Unable to resolve @weave-framework/nx:build").
!packages/nx/src/executors/build/
!packages/nx/src/executors/build/**
# Staged, pre-compiled @weave-framework/ui tree (tools/build-ui-components.mjs)
packages/ui/.compiled/
# Transient bundle emitted by tools/verify-dev-proxy.mjs (cleaned on exit)
tools/.verify-dev-proxy-bundle.mjs
*.tsbuildinfo
# Generated by `weave routes` (file-based routing)
**/routes.gen.ts
# Generated by docs/tools/gen-content.mjs — the full slug→markdown map (search index only), plus one
# module per page so a page's markdown lands in that page's chunk instead of every page's download.
docs/src/content/content.gen.ts
docs/src/content/**/*.gen.ts
# Generated by docs/tools/gen-api.mjs (API reference data)
docs/src/content/api.gen.ts
*.vsix
# ...except the published, downloadable plugin artifacts (this dir ships to public)
!plugins/editor/**/*.vsix

# Test / tooling artifacts
test-results/
playwright-report/
coverage/

# Logs
*.log
npm-debug.log*

# Editor / OS
.vscode/
.DS_Store
Thumbs.db
.idea/
*.swp

# transient esbuild bundle from the cli styles-assets smoke
packages/cli/test/.smoke-*/
